{
  "name": "@agenticmail/voice-host-bridge",
  "version": "0.1.0",
  "description": "Localhost realtime voice host bridge for AgenticMail phone calls",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenticmail-voice-host-bridge": "dist/cli.js",
    "agenticmail-meet-sidecar": "dist/meet-sidecar-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./meet-sidecar": {
      "types": "./dist/meet-sidecar.d.ts",
      "import": "./dist/meet-sidecar.js",
      "require": "./dist/meet-sidecar.cjs"
    },
    "./meet-sidecar-cli": {
      "types": "./dist/meet-sidecar-cli.d.ts",
      "import": "./dist/meet-sidecar-cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/meet-sidecar.ts --format esm,cjs --dts --clean --target node20 && tsup src/cli.ts src/meet-sidecar-cli.ts --format esm --dts --target node20",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticmail/agenticmail.git",
    "directory": "packages/voice-host-bridge"
  },
  "homepage": "https://github.com/agenticmail/agenticmail",
  "bugs": "https://github.com/agenticmail/agenticmail/issues",
  "keywords": [
    "agenticmail",
    "voice",
    "realtime",
    "openclaw",
    "codex",
    "claude-code",
    "phone"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Ope Olatunji",
  "license": "MIT"
}
